[gd_scene format=3 uid="uid://dcv532a5ccum8"]

[sub_resource type="GDScript" id="GDScript_36jy3"]
script/source = "extends Control

var floor_buttons_container: VBoxContainer

func _ready() -> void:
	visible = false
	set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT)
	
	# dim background
	var bg = ColorRect.new()
	bg.set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT)
	bg.color = Color(0, 0, 0, 0.6)
	add_child(bg)
	
	# panel
	var panel = PanelContainer.new()
	panel.set_anchors_preset(Control.PRESET_CENTER)
	panel.custom_minimum_size = Vector2(300, 400)
	add_child(panel)
	
	var vbox = VBoxContainer.new()
	vbox.add_theme_constant_override(\"separation\", 10)
	panel.add_child(vbox)
	
	# title
	var title = Label.new()
	title.text = \"ELEVATOR\"
	title.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	vbox.add_child(title)
	
	# subtitle
	var subtitle = Label.new()
	subtitle.text = \"Select a floor\"
	subtitle.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	vbox.add_child(subtitle)
	
	# floor buttons container
	floor_buttons_container = VBoxContainer.new()
	floor_buttons_container.add_theme_constant_override(\"separation\", 8)
	vbox.add_child(floor_buttons_container)
	
	# close button
	var close_btn = Button.new()
	close_btn.text = \"Cancel\"
	close_btn.pressed.connect(_on_close)
	vbox.add_child(close_btn)
	
	# close on bg click
	bg.gui_input.connect(func(event):
		if event is InputEventMouseButton and event.pressed:
			_on_close()
	)

func open(current_floor: int) -> void:
	# clear old buttons
	for child in floor_buttons_container.get_children():
		child.queue_free()
	
	if not GameManager.ss.is_minigame_cleared(\"jigsaw\"):
		var lbl = Label.new()
		lbl.text = \"Elevator locked.\\nComplete Floor 2 minigame first.\"
		lbl.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
		floor_buttons_container.add_child(lbl)
		visible = true
		return
	
	var floors: Array[int] = [2, 3, 4, 5, 6]
	if GameManager.ss.is_adrenaline_active():
		floors.append(7)
	
	for floor_num in floors:
		var btn = Button.new()
		if floor_num == current_floor:
			btn.text = \"Floor %d  ◄ you are here\" % floor_num
			btn.disabled = true
		else:
			btn.text = \"Floor %d\" % floor_num
			btn.pressed.connect(_on_floor_pressed.bind(floor_num))
		floor_buttons_container.add_child(btn)
	
	visible = true

func _on_floor_pressed(floor_num: int) -> void:
	visible = false
	GameManager.current_floor = floor_num
	GameManager.change_room(\"res://scenes/rooms/Floor%d.tscn\" % floor_num)

func _on_close() -> void:
	visible = false
	# force hide all children too
	for child in get_children():
		child.visible = false
"

